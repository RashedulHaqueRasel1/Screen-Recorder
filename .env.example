# Copy this file to .env and fill in real values.
# .env is gitignored and never committed.

# ---------------------------------------------------------------------------
# Google OAuth Credentials
# Create an OAuth 2.0 Client ID (type: Web application) at:
#   https://console.cloud.google.com/apis/credentials
# Then add the following Authorized redirect URI to that client:
#   http://localhost:3000/api/auth/callback/google        (dev)
#   https://<your-domain>/api/auth/callback/google         (prod)
# ---------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret

# ---------------------------------------------------------------------------
# Auth.js (NextAuth v5) configuration
# ---------------------------------------------------------------------------

# Secret used to sign/encrypt the session JWT.
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-output-of-openssl-rand-base64-32

# Canonical app URL used by Auth.js to build OAuth redirect URIs.
# Dev:  http://localhost:3000
# Prod: https://<your-domain>
AUTH_URL=http://localhost:3000

# Trust the host header. Required for Auth.js v5 on any non-Vercel host
# (Docker, bare-metal, most PaaS providers). Safe to leave on.
AUTH_TRUST_HOST=true
